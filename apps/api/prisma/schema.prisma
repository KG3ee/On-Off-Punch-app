generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
  DRIVER
  LEADER
  MAID
  CHEF
}

enum AssignmentTargetType {
  TEAM
  USER
}

enum DutySessionStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum BreakSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  AUTO_CLOSED
}

enum RegistrationRequestStatus {
  PENDING
  READY_REVIEW
  APPROVED
  REJECTED
}


enum ShiftChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ShiftRequestType {
  HALF_DAY_MORNING
  HALF_DAY_EVENING
  FULL_DAY_OFF
  CUSTOM
}

enum DriverStatus {
  AVAILABLE
  BUSY
  ON_BREAK
  OFFLINE
}

enum DriverRequestStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DriverRequestCategory {
  GENERAL
  MEAL_PICKUP
}

enum NotificationType {
  DRIVER_REQUEST_CREATED
  DRIVER_REQUEST_APPROVED
  DRIVER_REQUEST_REJECTED
  DRIVER_REQUEST_IN_PROGRESS
  DRIVER_REQUEST_COMPLETED
  VIOLATION_CREATED
  VIOLATION_TRIAGED
  VIOLATION_FINALIZED
  SHIFT_REQUEST_SUBMITTED
  SHIFT_REQUEST_REVIEWED
  REGISTRATION_REQUEST_SUBMITTED
  REGISTRATION_REQUEST_REVIEWED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ViolationSource {
  MEMBER_REPORT
  LEADER_OBSERVED
  ADMIN_OBSERVED
}

enum ViolationStatus {
  PENDING
  LEADER_VALID
  LEADER_INVALID
  CONFIRMED
  REJECTED
}

enum ViolationReason {
  LEFT_WITHOUT_PUNCH
  UNAUTHORIZED_ABSENCE
  OTHER
}

enum ViolationLedgerType {
  REWARD
  DEDUCTION
}

enum ViolationLedgerReason {
  REPORT_REWARD
  ACCUSED_DEDUCTION
  COLLECTIVE_DEDUCTION
}

enum DeductionCategory {
  PUNCH_LATE
  BREAK_LATE
}

enum DeductionSourceType {
  DUTY_SESSION
  BREAK_SESSION
}

model Team {
  id             String  @id @default(cuid())
  name           String  @unique
  shiftStartTime String? // e.g. "09:00"
  shiftEndTime   String? // e.g. "18:00"
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users         User[]
  shiftPresets  ShiftPreset[]
  dutySessions  DutySession[]
  monthlyReports MonthlyReport[]
  registrationRequests RegistrationRequest[]
}

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  passwordHash String
  mustChangePassword Boolean @default(true)
  firstName  String
  lastName   String?
  displayName     String
  contactNumber   String?
  profilePhotoUrl String?
  role            Role     @default(MEMBER)
  isActive        Boolean  @default(true)
  teamId          String?
  driverStatus    DriverStatus @default(OFFLINE)
  vehicleInfo     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team Team? @relation(fields: [teamId], references: [id])

  createdDutySessions  DutySession[] @relation("CreatedDutySessions")
  createdBreakSessions BreakSession[] @relation("CreatedBreakSessions")
  cancelledBreakSessions BreakSession[] @relation("CancelledBreakSessions")
  auditEvents AuditEvent[]
  monthlyReportsGenerated MonthlyReport[] @relation("MonthlyReportsGeneratedBy")

  dutySessions DutySession[]
  breakSessions BreakSession[]
  reviewedRegistrationRequests RegistrationRequest[] @relation("ReviewedRegistrationRequests")
  approvedRegistrationRequests RegistrationRequest[] @relation("ApprovedRegistrationRequests")

  shiftChangeRequests ShiftChangeRequest[]
  reviewedShiftChangeRequests ShiftChangeRequest[] @relation("ReviewedShiftChangeRequests")

  driverRequestsCreated DriverRequest[] @relation("DriverRequestsCreated")
  driverRequestsAssigned DriverRequest[] @relation("DriverRequestsAssigned")
  driverRequestsReviewed DriverRequest[] @relation("DriverRequestsReviewed")
  pushSubscriptions PushSubscription[]
  notifications UserNotification[]
  clientActionReceipts ClientActionReceipt[]
  clientRefMappings ClientRefMapping[]
  violationsCreated ViolationCase[] @relation("ViolationCreatedByUser")
  violationsAccused ViolationCase[] @relation("ViolationAccusedUser")
  violationsLeaderReviewed ViolationCase[] @relation("ViolationLeaderReviewedByUser")
  violationsAdminReviewed ViolationCase[] @relation("ViolationAdminReviewedByUser")
  violationPoints ViolationPointEntry[] @relation("ViolationPointTargetUser")
  violationPointsCreated ViolationPointEntry[] @relation("ViolationPointCreatedByUser")
  deductionEntries DeductionEntry[]

  @@index([teamId])
  @@index([role])
}

model ClientActionReceipt {
  id                    String   @id @default(cuid())
  userId                String
  clientDeviceId        String
  clientActionId        String
  actionType            String
  clientTimestamp       DateTime?
  serverReceivedAt      DateTime @default(now())
  status                String
  rejectionReason       String?
  resolvedDutySessionId String?
  resolvedBreakSessionId String?
  responseJson          Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientDeviceId, clientActionId])
  @@index([userId, clientDeviceId, createdAt])
  @@index([resolvedDutySessionId])
  @@index([resolvedBreakSessionId])
}

model ClientRefMapping {
  id             String   @id @default(cuid())
  userId         String
  clientDeviceId String
  refType        String
  clientRef      String
  dutySessionId  String?
  breakSessionId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientDeviceId, refType, clientRef])
  @@index([dutySessionId])
  @@index([breakSessionId])
}

model RegistrationRequest {
  id              String                    @id @default(cuid())
  staffCode       String

  firstName       String
  lastName        String?
  displayName     String
  desiredUsername String
  passwordHash    String
  status          RegistrationRequestStatus @default(PENDING)
  requestedTeamId String?
  reviewNote      String?
  reviewedAt      DateTime?
  reviewedById    String?
  approvedUserId  String?
  submittedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requestedTeam Team? @relation(fields: [requestedTeamId], references: [id])
  reviewedBy User? @relation("ReviewedRegistrationRequests", fields: [reviewedById], references: [id])
  approvedUser User? @relation("ApprovedRegistrationRequests", fields: [approvedUserId], references: [id])

  @@index([status, submittedAt])
  @@index([desiredUsername])
  @@index([staffCode])
  @@index([requestedTeamId])
}

model ShiftPreset {
  id          String   @id @default(cuid())
  name        String
  timezone    String   @default("Asia/Dubai")
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  teamId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team Team? @relation(fields: [teamId], references: [id])

  segments     ShiftPresetSegment[]
  assignments  ShiftAssignment[]
  overrides    ShiftOverride[]
  dutySessions DutySession[]
  shiftChangeRequests ShiftChangeRequest[]

  @@index([teamId, isDefault])
}

model ShiftPresetSegment {
  id               String  @id @default(cuid())
  shiftPresetId    String
  segmentNo        Int
  startTime        String
  endTime          String
  crossesMidnight  Boolean @default(false)
  lateGraceMinutes Int     @default(10)

  shiftPreset ShiftPreset @relation(fields: [shiftPresetId], references: [id], onDelete: Cascade)
  dutySessions DutySession[]

  @@unique([shiftPresetId, segmentNo])
  @@index([shiftPresetId])
}

model ShiftAssignment {
  id            String               @id @default(cuid())
  targetType    AssignmentTargetType
  targetId      String
  shiftPresetId String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shiftPreset ShiftPreset @relation(fields: [shiftPresetId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, effectiveFrom])
  @@index([targetType, targetId, isActive, effectiveFrom])
  @@index([shiftPresetId])
}

model ShiftOverride {
  id            String               @id @default(cuid())
  targetType    AssignmentTargetType
  targetId      String
  shiftPresetId String
  overrideDate  DateTime
  reason        String?
  createdAt     DateTime @default(now())

  shiftPreset ShiftPreset @relation(fields: [shiftPresetId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, overrideDate])
  @@index([shiftPresetId])
}

model DutySession {
  id                   String            @id @default(cuid())
  userId               String
  teamId               String?
  shiftPresetId        String?
  shiftPresetSegmentId String?
  shiftDate            String
  localDate            String
  scheduledStartLocal  String?
  scheduledEndLocal    String?
  punchedOnAt          DateTime
  punchedOffAt         DateTime?
  status               DutySessionStatus @default(ACTIVE)
  isLate               Boolean           @default(false)
  lateMinutes          Int               @default(0)
  overtimeMinutes      Int               @default(0)
  note                 String?
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  team Team? @relation(fields: [teamId], references: [id])
  shiftPreset ShiftPreset? @relation(fields: [shiftPresetId], references: [id])
  shiftPresetSegment ShiftPresetSegment? @relation(fields: [shiftPresetSegmentId], references: [id])
  createdBy User? @relation("CreatedDutySessions", fields: [createdById], references: [id])

  breakSessions BreakSession[]

  @@index([userId, localDate])
  @@index([userId, localDate, status])
  @@index([userId, status])
  @@index([status])
  @@index([localDate, status])
  @@index([teamId, localDate])
  @@index([status, punchedOnAt])
}


model ShiftChangeRequest {
  id              String   @id @default(cuid())
  userId          String
  shiftPresetId   String?
  requestType     ShiftRequestType @default(CUSTOM)
  requestedDate   DateTime
  reason          String?
  status          ShiftChangeRequestStatus @default(PENDING)
  adminNote       String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id])
  shiftPreset     ShiftPreset? @relation(fields: [shiftPresetId], references: [id])
  reviewedBy      User? @relation("ReviewedShiftChangeRequests", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
}

model DriverRequest {
  id            String             @id @default(cuid())
  userId        String
  category      DriverRequestCategory @default(GENERAL)
  requestedDate DateTime
  requestedTime String
  destination   String
  purpose       String?
  isRoundTrip    Boolean            @default(false)
  returnDate     DateTime?
  returnTime     String?
  returnLocation String?
  contactNumber String?
  status        DriverRequestStatus @default(PENDING)
  driverId      String?
  adminNote     String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user        User  @relation("DriverRequestsCreated", fields: [userId], references: [id])
  driver      User? @relation("DriverRequestsAssigned", fields: [driverId], references: [id])
  reviewedBy  User? @relation("DriverRequestsReviewed", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
  @@index([driverId])
}

model PushSubscription {
  id                String   @id @default(cuid())
  userId            String
  endpoint          String   @unique
  p256dh            String
  auth              String
  deviceLabel       String?
  userAgent         String?
  isActive          Boolean  @default(true)
  failureCount      Int      @default(0)
  lastSuccessAt     DateTime?
  lastFailureAt     DateTime?
  lastFailureReason String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model UserNotification {
  id          String               @id @default(cuid())
  userId      String
  type        NotificationType
  priority    NotificationPriority @default(NORMAL)
  title       String
  body        String
  link        String?
  payloadJson Json?
  isRead      Boolean              @default(false)
  readAt      DateTime?
  createdAt   DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
}

model BreakPolicy {
  id                      String  @id @default(cuid())
  code                    String  @unique
  name                    String
  expectedDurationMinutes Int
  dailyLimit              Int
  isActive                Boolean @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  breakSessions BreakSession[]
}

model BreakSession {
  id                     String             @id @default(cuid())
  userId                 String
  dutySessionId          String?
  breakPolicyId          String
  localDate              String
  startedAt              DateTime
  endedAt                DateTime?
  expectedDurationMinutes Int
  actualMinutes          Int?
  status                 BreakSessionStatus @default(ACTIVE)
  isOvertime             Boolean            @default(false)
  autoClosed             Boolean            @default(false)
  cancelledAt            DateTime?
  createdById            String?
  cancelledById          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  dutySession DutySession? @relation(fields: [dutySessionId], references: [id])
  breakPolicy BreakPolicy @relation(fields: [breakPolicyId], references: [id])
  createdBy User? @relation("CreatedBreakSessions", fields: [createdById], references: [id])
  cancelledBy User? @relation("CancelledBreakSessions", fields: [cancelledById], references: [id])

  @@index([userId, localDate])
  @@index([userId, localDate, status])
  @@index([userId, status])
  @@index([status])
  @@index([localDate, status])
  @@index([startedAt])
}

model MonthlyReport {
  id           String  @id @default(cuid())
  scopeKey     String  @unique
  year         Int
  month        Int
  teamId       String?
  periodStart  DateTime
  periodEnd    DateTime
  reportJson   Json
  generatedById String?
  generatedAt  DateTime @default(now())

  team Team? @relation(fields: [teamId], references: [id])
  generatedBy User? @relation("MonthlyReportsGeneratedBy", fields: [generatedById], references: [id])

  @@index([year, month])
  @@index([teamId])
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorUserId String?
  action     String
  entityType String
  entityId   String
  payload    Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([action])
}

model ViolationCase {
  id                 String          @id @default(cuid())
  source             ViolationSource
  status             ViolationStatus @default(PENDING)
  reason             ViolationReason
  accusedUserId      String
  createdByUserId    String
  occurredAt         DateTime
  localDate          String
  note               String?
  leaderReviewedById String?
  leaderReviewedAt   DateTime?
  leaderReviewNote   String?
  adminReviewedById  String?
  adminReviewedAt    DateTime?
  adminReviewNote    String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  accusedUser       User   @relation("ViolationAccusedUser", fields: [accusedUserId], references: [id])
  createdByUser     User   @relation("ViolationCreatedByUser", fields: [createdByUserId], references: [id])
  leaderReviewedBy  User?  @relation("ViolationLeaderReviewedByUser", fields: [leaderReviewedById], references: [id], onDelete: SetNull)
  adminReviewedBy   User?  @relation("ViolationAdminReviewedByUser", fields: [adminReviewedById], references: [id], onDelete: SetNull)
  pointEntries      ViolationPointEntry[]

  @@index([status, createdAt])
  @@index([accusedUserId, occurredAt])
  @@index([localDate])
}

model ViolationPointEntry {
  id              String               @id @default(cuid())
  violationCaseId String
  userId          String
  type            ViolationLedgerType
  reason          ViolationLedgerReason
  points          Int
  localDate       String
  note            String?
  createdByUserId String?
  createdAt       DateTime             @default(now())

  violationCase ViolationCase @relation(fields: [violationCaseId], references: [id], onDelete: Cascade)
  user          User          @relation("ViolationPointTargetUser", fields: [userId], references: [id])
  createdByUser User?         @relation("ViolationPointCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([localDate])
}

model DeductionTier {
  id           String            @id @default(cuid())
  category     DeductionCategory
  occurrenceNo Int
  amountAed    Decimal           @db.Decimal(10, 2)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([category, occurrenceNo])
  @@index([category])
}

model DeductionPolicy {
  id                     String            @id @default(cuid())
  category               DeductionCategory @unique
  effectiveFromLocalDate String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([category])
}

model DeductionEntry {
  id                           String              @id @default(cuid())
  userId                       String
  category                     DeductionCategory
  sourceType                   DeductionSourceType
  sourceId                     String
  localDate                    String
  periodMonth                  String
  occurrenceNo                 Int
  amountAed                    Decimal             @db.Decimal(10, 2)
  currency                     String              @default("AED")
  lateMinutesSnapshot          Int?
  breakOvertimeMinutesSnapshot Int?
  createdAt                    DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId])
  @@index([userId, periodMonth, category])
  @@index([periodMonth, category])
}
