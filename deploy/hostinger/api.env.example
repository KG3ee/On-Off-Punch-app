DATABASE_URL=postgresql://user:password@host:5432/modern_punch
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/modern_punch
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
APP_TIMEZONE=Asia/Dubai
# Set to your web domain. Comma-separated list; wildcards supported (e.g. https://*.example.com)
CORS_ORIGIN=https://app.example.com
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=true
AUTH_SESSION_DAYS=30
BODY_LIMIT=2mb
JOB_SECRET=replace-with-a-strong-job-secret
SYSTEM_JOB_USER_ID=
MAX_ACTIVE_DUTY_HOURS=20
MAX_CLIENT_PAST_HOURS=72
MAX_CLIENT_FUTURE_MINUTES=2
HIGH_TRUST_SKEW_MINUTES=2
MAX_LATE_MINUTES=720
MAX_OVERTIME_MINUTES=720
BCRYPT_ROUNDS=12
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
