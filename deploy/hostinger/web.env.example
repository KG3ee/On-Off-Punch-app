# IMPORTANT: NEXT_PUBLIC_API_URL must also be set as a Docker build arg in compose.env
# (see compose.env.example). This env_file copy only affects server-side runtime;
# the client JS bundle value is locked in at image build time.
NEXT_PUBLIC_API_URL=https://api.example.com
API_INTERNAL_URL=http://api:4000
JOB_SECRET=replace-with-the-same-job-secret-used-by-api
NEXT_PUBLIC_PUSH_ENABLED=false
NEXT_PUBLIC_PUSH_ROLES=ADMIN,LEADER,DRIVER,MEMBER,CHEF,MAID
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
